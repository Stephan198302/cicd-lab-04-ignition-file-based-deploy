#!/bin/bash
# Auto-apply skip-worktree to tracked resource.json files under the Ignition
# config/project trees. Ignition rewrites these on every gateway interaction
# with machine-specific values; without skip-worktree they pollute every
# developer's git status.
#
# Sourced from post-merge, post-checkout, and post-rewrite hooks. New files
# Ignition creates show up as untracked (so a developer can `git add` them);
# once tracked, the next checkout/merge auto-skips them.
#
# To intentionally update a seed file:
#   git update-index --no-skip-worktree <path>
#   <edit, commit, push>
#   (next pull re-applies skip-worktree)

set -e

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
cd "$REPO_ROOT"

git ls-files -- \
    'services/ignition-*/config/resources/*resource.json' \
    'services/ignition-*/config/resources/**/resource.json' \
    'projects/**/resource.json' \
    'services/ignition-it/config/resources/local/ignition/local-system-properties/config.json' \
    'services/ignition-ot/config/resources/local/ignition/local-system-properties/config.json' \
  | while IFS= read -r f; do
        # Only skip if not already skipped (avoids redundant index writes)
        if ! git ls-files -v -- "$f" 2>/dev/null | grep -q '^S'; then
            git update-index --skip-worktree -- "$f" 2>/dev/null || true
        fi
    done
