# Copy this file to .env (which is gitignored) before running `docker compose up`.
# Override the defaults for local development.

# Gateway admin credentials. First-time login uses these.
GATEWAY_ADMIN_USERNAME=admin
GATEWAY_ADMIN_PASSWORD=lab04password

# Postgres credentials for the sidecar.
POSTGRES_USER=ignition
POSTGRES_PASSWORD=ignition
POSTGRES_DB=ignition

# Ignition API key — used by the deploy scripts and workflow to hit the
# /data/api/v1/scan/{projects,config} endpoints. Generate one in the gateway UI:
# Config → Security → API Keys → New.
# Put the real value in .env (NOT here); CI uses a repo secret with the same name.
IGNITION_API_KEY=replace-me-in-.env-and-in-repo-secrets
