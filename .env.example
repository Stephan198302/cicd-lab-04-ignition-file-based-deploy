# Copy this file to .env (which is gitignored) before running `docker compose up`.
# Override the defaults for local development.
#
# This lab runs THREE Ignition gateways (local / dev / prod). Each gateway has
# its own admin credentials and its own API key. Local credentials are used
# at first login; dev/prod credentials are only needed when you click into
# those gateways' UIs.
#
# API keys are generated in each gateway's UI:
#   Config → Security → API Keys → New (role with Project Scan + Config Scan).
# For CI, IGNITION_API_KEY_DEV / _PROD are duplicated as GitHub environment
# secrets named IGNITION_API_KEY on the lab-gateway-dev / lab-gateway-prod
# environments. See README.md for the full setup.

# ---- Local gateway (http://localhost:8088) ------------------------------
GATEWAY_ADMIN_USERNAME_LOCAL=admin
GATEWAY_ADMIN_PASSWORD_LOCAL=password
IGNITION_API_KEY_LOCAL=replace-me-after-first-login

# ---- Dev gateway (http://localhost:8089) — deploy.yml target ------------
GATEWAY_ADMIN_USERNAME_DEV=admin
GATEWAY_ADMIN_PASSWORD_DEV=password
IGNITION_API_KEY_DEV=replace-me-after-first-login

# ---- Prod gateway (http://localhost:8090) — release.yml target ----------
GATEWAY_ADMIN_USERNAME_PROD=admin
GATEWAY_ADMIN_PASSWORD_PROD=password
IGNITION_API_KEY_PROD=replace-me-after-first-login

# ---- Backward-compat single key (optional) ------------------------------
# Older scripts/CI workflows that don't set a per-gateway key fall back to
# this. You can leave it unset; scan.sh will pick the right
# IGNITION_API_KEY_<GATEWAY> based on the --gateway flag.
# IGNITION_API_KEY=

# ---- Shared TimescaleDB sidecar ------------------------------------------
# One Postgres instance, three databases (ignition_loc, ignition_dev,
# ignition_prd). These creds are the superuser; create per-env users via
# the gateway DB connection UI if you want isolation.
POSTGRES_USER=ignition
POSTGRES_PASSWORD=ignition

# ---- GitHub Actions self-hosted runner ----------------------------------
# The bundled runner registers with a short-lived registration token — no PAT.
# scripts/setup.sh mints that token for you with the GitHub CLI (the same no-PAT
# method Lab 03 uses), so all you set here is your fork's URL. Just make sure gh
# is installed and authenticated first: `gh auth login`.
#
# RUNNER_REPO_URL is your fork (not the upstream mustry-academy repo).
RUNNER_REPO_URL=https://github.com/<your-github-user>/cicd-lab-04-ignition-file-based-deploy
RUNNER_NAME=lab04-runner
